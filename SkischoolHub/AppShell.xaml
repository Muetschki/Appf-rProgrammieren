<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SkischoolHub.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SkischoolHub.Views"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="Registrierung"
        ContentTemplate="{DataTemplate local:RegistrationPage}"
        Route="RegistrationPage" />

    <ShellContent
        Title="Start"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Privatstunden"
        ContentTemplate="{DataTemplate local:PrivateLessonPage}"
        Route="PrivateLessonPage" />

</Shell>